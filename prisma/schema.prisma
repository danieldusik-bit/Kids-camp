generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Registration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  status    String   @default("Новая")

  // Which camp
  camp      String   @default("kids")
  groupWith String   @default("")

  // Parent / Guardian
  parentName  String
  parentPhone String
  parentEmail String

  // Emergency contact (optional)
  emergencyContactName  String @default("")
  emergencyContactPhone String @default("")

  // Child info
  childName     String
  childDOB      String
  childAge      Int
  childPersonalId String @default("")
  childLanguage   String @default("Русский")
  childGender     String @default("")

  // Location
  city String

  // Billing details
  billingName    String @default("")
  billingId      String @default("")
  billingAddress String @default("")
  billingEmail   String @default("")

  // Pickup — legacy free-text fields, kept for backwards compatibility
  pickupAuthorized   String  @default("")
  childCanLeaveAlone Boolean @default(false)

  // Pickup — structured contacts (new form)
  pickup1Name     String @default("")
  pickup1Phone    String @default("")
  pickup1Relation String @default("")
  pickup2Name     String @default("")
  pickup2Phone    String @default("")
  pickup2Relation String @default("")

  // Health
  hasAllergies        Boolean @default(false)
  allergiesDetails    String  @default("")
  hasChronicIllness   Boolean @default(false)
  chronicDetails      String  @default("")
  takesMedication     Boolean @default(false)
  medicationDetails   String  @default("")
  physicalActivity    String  @default("Разрешено")
  physicalLimitations String  @default("")

  // Behavioural / extra health
  hasSpecialTraits        Boolean @default(false)
  specialTraitsDetails    String  @default("")
  hasEncephalitisVaccine  String  @default("")
  participatedOtherCamps  String  @default("")

  // Diet
  dietRestrictions String @default("нет")
  dietDetails      String @default("")

  // Additional
  additionalInfo String @default("")
  hearAboutUs    String @default("")

  // Confirmations
  confirmInfoTrue   Boolean @default(false)
  confirmFirstAid   Boolean @default(false)
  confirmRules      Boolean @default(false)
  confirmPayment    Boolean @default(false)

  // Legacy / general health field kept for compatibility
  healthInfo    String @default("")
  internalNotes String @default("")

  // Team assignment
  teamId String?
}

model Team {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  camp      String // "kids" | "teens"
  gender    String // "boy" | "girl"
  number    Int // 1..12 (or more)
  name      String   @default("")
  leaderId  String? // User id of the mentor leading this team

  @@unique([camp, gender, number])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("VIEWER")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}
